@page "/"

<PageTitle>ECommerce</PageTitle>

<h1>ECommerce</h1>

<p>A sample microservices application built with .NET 10, ASP.NET Core, and .NET Aspire.</p>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Catalog</h5>
                <p class="card-text">Browse products and place an order.</p>
                <a class="btn btn-primary" href="/products">Open Catalog</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Orders</h5>
                <p class="card-text">View orders placed across the system.</p>
                <a class="btn btn-primary" href="/orders">View Orders</a>
            </div>
        </div>
    </div>
</div>
