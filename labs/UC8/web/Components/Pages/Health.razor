@page "/health-dashboard"
@using ECommerce.Web.Services
@inject HealthApiClient Health
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Service health</PageTitle>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1 class="mb-0">Service health</h1>
    <button class="btn btn-sm btn-outline-secondary" @onclick="Refresh">Refresh</button>
</div>
<p class="text-muted mt-2">Liveness of each service, polled through the gateway (auto-refresh: 10 s).</p>

<div class="row g-3 mt-1">
    @foreach (var svc in _statuses)
    {
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="h5 card-title mb-1">@svc.Name</h2>
                        <span class="text-muted small">@svc.Path</span>
                    </div>
                    <span class="badge @BadgeClass(svc.State)">
                        <span class="visually-hidden">Status: </span>@svc.State
                    </span>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<ServiceHealth> _statuses = HealthApiClient.Targets
        .Select(t => new ServiceHealth(t.Name, t.Path, "Checking…"))
        .ToList();
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        // Auto-refresh ; InvokeAsync repasse sur le thread du circuit Blazor.
        _timer = new Timer(async _ => await InvokeAsync(Refresh), null, 10_000, 10_000);
    }

    private async Task Refresh()
    {
        _statuses = await Health.CheckAllAsync();
        StateHasChanged();
    }

    // Statut = couleur + TEXTE (le texte "@svc.State" reste lisible sans la couleur).
    private static string BadgeClass(string state) => state switch
    {
        "Healthy"   => "text-bg-success",
        "Unhealthy" => "text-bg-danger",
        _           => "text-bg-secondary"
    };

    public void Dispose() => _timer?.Dispose();
}
